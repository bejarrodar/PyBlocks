          "indent": false,
          "x": 0,
          "y": 0
        },
        {
          "id": "sn27c11",
          "type": "for_block",
          "label_template": "FOR {target} IN {iterable}:",
          "inputs": { "target": "seg", "iterable": "snake" },
          "color": "#fab387",
          "indent": true,
          "x": 0,
          "y": 0,
          "children": [
            {
              "id": "sn27c11c0",
              "type": "expr_block",
