    {
      "id": "sn27",
      "type": "while_block",
      "label_template": "WHILE {condition}:",
      "inputs": { "condition": "running" },
      "color": "#fab387",
      "indent": true,
      "x": 40,
      "y": 1100,
      "children": [
        {
          "id": "sn27c0",
          "type": "for_block",
          "label_template": "FOR {target} IN {iterable}:",
          "inputs": { "target": "event", "iterable": "pygame.event.get()" },
          "color": "#fab387",
          "indent": true,
          "x": 0,
          "y": 0,
          "children": [
            {
              "id": "sn27c0c0",
              "type": "if_block",
              "label_template": "IF {condition}:",
              "inputs": { "condition": "event.type == pygame.QUIT" },
              "color": "#cba6f7",
              "indent": true,
              "x": 0,
              "y": 0,
              "children": [
                {
                  "id": "sn27c0c0c0",
                  "type": "assign_block",
                  "label_template": "SET {name} = {value}",
                  "inputs": { "name": "running", "value": "False" },
                  "children": [],
                  "color": "#89b4fa",
                  "indent": false,
                  "x": 0,
                  "y": 0
                }
              ]
            },
            {
              "id": "sn27c0c1",
              "type": "if_block",
              "label_template": "IF {condition}:",
              "inputs": { "condition": "event.type == pygame.KEYDOWN" },
              "color": "#cba6f7",
              "indent": true,
              "x": 0,
              "y": 0,
              "children": [
                {
                  "id": "sn27c0c1c0",
                  "type": "if_block",
                  "label_template": "IF {condition}:",
                  "inputs": { "condition": "event.key == pygame.K_UP and dy == 0" },
                  "color": "#cba6f7",
                  "indent": true,
                  "x": 0,
                  "y": 0,
                  "children": [
                    {
                      "id": "sn27c0c1c0c0",
                      "type": "expr_block",
                      "label_template": "{expr}",
                      "inputs": { "expr": "dx, dy = 0, -1" },
                      "children": [],
                      "color": "#7f849c",
                      "indent": false,
                      "x": 0,
                      "y": 0
                    }
                  ]
                },
                {
                  "id": "sn27c0c1c1",
                  "type": "elif_block",
                  "label_template": "ELIF {condition}:",
                  "inputs": { "condition": "event.key == pygame.K_DOWN and dy == 0" },
                  "color": "#b4befe",
                  "indent": true,
                  "x": 0,
                  "y": 0,
                  "children": [
                    {
                      "id": "sn27c0c1c1c0",
                      "type": "expr_block",
                      "label_template": "{expr}",
                      "inputs": { "expr": "dx, dy = 0, 1" },
                      "children": [],
                      "color": "#7f849c",
                      "indent": false,
                      "x": 0,
                      "y": 0
                    }
                  ]
                },
                {
                  "id": "sn27c0c1c2",
                  "type": "elif_block",
                  "label_template": "ELIF {condition}:",
                  "inputs": { "condition": "event.key == pygame.K_LEFT and dx == 0" },
                  "color": "#b4befe",
                  "indent": true,
                  "x": 0,
                  "y": 0,
                  "children": [
                    {
                      "id": "sn27c0c1c2c0",
                      "type": "expr_block",
                      "label_template": "{expr}",
                      "inputs": { "expr": "dx, dy = -1, 0" },
                      "children": [],
                      "color": "#7f849c",
                      "indent": false,
                      "x": 0,
                      "y": 0
                    }
                  ]
                },
                {
                  "id": "sn27c0c1c3",
                  "type": "elif_block",
                  "label_template": "ELIF {condition}:",
                  "inputs": { "condition": "event.key == pygame.K_RIGHT and dx == 0" },
                  "color": "#b4befe",
                  "indent": true,
                  "x": 0,
                  "y": 0,
                  "children": [
                    {
                      "id": "sn27c0c1c3c0",
                      "type": "expr_block",
                      "label_template": "{expr}",
                      "inputs": { "expr": "dx, dy = 1, 0" },
                      "children": [],
                      "color": "#7f849c",
                      "indent": false,
                      "x": 0,
                      "y": 0
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "sn27c1",
          "type": "comment_block",
          "label_template": "# {text}",
          "inputs": { "text": "Move the snake head one step" },
          "children": [],
          "color": "#6c7086",
          "indent": false,
          "x": 0,
          "y": 0
        },
        {
          "id": "sn27c2",
          "type": "assign_block",
          "label_template": "SET {name} = {value}",
          "inputs": { "name": "hx", "value": "snake[0][0] + dx" },
          "children": [],
          "color": "#89b4fa",
          "indent": false,
          "x": 0,
          "y": 0
        },
        {
          "id": "sn27c3",
          "type": "assign_block",
          "label_template": "SET {name} = {value}",
          "inputs": { "name": "hy", "value": "snake[0][1] + dy" },
          "children": [],
          "color": "#89b4fa",
          "indent": false,
          "x": 0,
          "y": 0
        },
        {
          "id": "sn27c4",
          "type": "if_block",
          "label_template": "IF {condition}:",
          "inputs": { "condition": "hx < 0 or hx >= COLS or hy < 0 or hy >= ROWS" },
          "color": "#cba6f7",
          "indent": true,
          "x": 0,
          "y": 0,
          "children": [
            {
              "id": "sn27c4c0",
              "type": "assign_block",
              "label_template": "SET {name} = {value}",
              "inputs": { "name": "running", "value": "False" },
              "children": [],
              "color": "#89b4fa",
              "indent": false,
              "x": 0,
              "y": 0
            }
          ]
        },
        {
          "id": "sn27c5",
          "type": "if_block",
          "label_template": "IF {condition}:",
          "inputs": { "condition": "(hx, hy) in snake" },
          "color": "#cba6f7",
          "indent": true,
          "x": 0,
          "y": 0,
          "children": [
            {
              "id": "sn27c5c0",
              "type": "assign_block",
              "label_template": "SET {name} = {value}",
              "inputs": { "name": "running", "value": "False" },
              "children": [],
              "color": "#89b4fa",
              "indent": false,
              "x": 0,
              "y": 0
            }
          ]
        },
        {
          "id": "sn27c6",
          "type": "if_block",
          "label_template": "IF {condition}:",
          "inputs": { "condition": "(hx, hy) == food" },
          "color": "#cba6f7",
          "indent": true,
          "x": 0,
          "y": 0,
          "children": [
            {
              "id": "sn27c6c0",
              "type": "expr_block",
              "label_template": "{expr}",
              "inputs": { "expr": "score += 1" },
              "children": [],
              "color": "#7f849c",
              "indent": false,
              "x": 0,
              "y": 0
            },
            {
              "id": "sn27c6c1",
              "type": "assign_block",
              "label_template": "SET {name} = {value}",
              "inputs": { "name": "food", "value": "(random.randint(0, COLS - 1), random.randint(0, ROWS - 1))" },
              "children": [],
              "color": "#89b4fa",
              "indent": false,
              "x": 0,
              "y": 0
            }
          ]
        },
        {
          "id": "sn27c7",
          "type": "else_block",
          "label_template": "ELSE:",
          "inputs": {},
          "color": "#b4befe",
          "indent": true,
          "x": 0,
          "y": 0,
          "children": [
            {
              "id": "sn27c7c0",
              "type": "expr_block",
              "label_template": "{expr}",
              "inputs": { "expr": "snake.pop()" },
              "children": [],
              "color": "#7f849c",
              "indent": false,
              "x": 0,
              "y": 0
            }
          ]
        },
        {
          "id": "sn27c8",
          "type": "expr_block",
          "label_template": "{expr}",
          "inputs": { "expr": "snake.insert(0, (hx, hy))" },
          "children": [],
          "color": "#7f849c",
          "indent": false,
          "x": 0,
          "y": 0
        },
        {
          "id": "sn27c9",
          "type": "comment_block",
          "label_template": "# {text}",
          "inputs": { "text": "Draw everything" },
          "children": [],
